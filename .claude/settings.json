{
  "$comment": "Throughline repo-wide Claude Code config. Hooks encode the truth-model invariants from CLAUDE.md so they're caught at edit time. See .claude/hooks/*.mjs.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-protected.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-invariants.mjs"
          }
        ]
      }
    ]
  }
}
