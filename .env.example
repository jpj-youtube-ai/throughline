# Copy to .env (gitignored) and fill in. None of these are committed.

# Anthropic API key — task generation (src/generate.ts). A real API key from
# console.anthropic.com, NOT a Claude Code subscription token.
ANTHROPIC_API_KEY=

# Auth.js — GitHub OAuth App for sign-in (REQ-001).
#   AUTH_SECRET: generate with `npx auth secret`
#   AUTH_GITHUB_ID / AUTH_GITHUB_SECRET: from a GitHub OAuth App whose callback
#   is http://localhost:3000/api/auth/callback/github (dev).
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Postgres for the app + genesis import. Omit to use embedded PGlite in tests.
DATABASE_URL=

# GitHub App (repo issues/contents/PRs + webhooks) — REQ-002. SEPARATE from the
# sign-in OAuth above.
#   GITHUB_APP_ID: the App's numeric id.
#   GITHUB_APP_PRIVATE_KEY: the App's PEM private key, \n-escaped on one line.
#   GITHUB_APP_CLIENT_ID / SECRET: for the App install/setup flow.
#   GITHUB_WEBHOOK_SECRET: verifies incoming webhooks (REQ-009).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Where local repo clones are kept (REQ-002).
REPO_CLONE_ROOT=./.clones
