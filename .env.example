# Copy to .env (gitignored) and fill in. None of these are committed.

# Anthropic API key — task generation (src/generate.ts). A real API key from
# console.anthropic.com, NOT a Claude Code subscription token.
ANTHROPIC_API_KEY=

# Auth.js — GitHub OAuth App for sign-in (REQ-001).
#   AUTH_SECRET: generate with `npx auth secret`
#   AUTH_GITHUB_ID / AUTH_GITHUB_SECRET: from a GitHub OAuth App whose callback
#   is http://localhost:3000/api/auth/callback/github (dev).
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Postgres for the app + genesis import. Omit to use embedded PGlite in tests.
DATABASE_URL=
